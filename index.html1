<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>서울 월별 기온 현황 대시보드</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg-color: #f4f7f9;
            --card-bg: #ffffff;
            --text-color: #2d3748;
            --border-color: #e2e8f0;
            --primary: #3182ce;
            --success: #38a169;
            --danger: #e53e3e;
            --warning: #dd6b20;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Malgun Gothic", "맑은 고딕", helvetica, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        header {
            margin-bottom: 25px;
            text-align: center;
        }

        header h1 {
            margin: 0 0 8px 0;
            color: var(--primary);
            font-size: 32px;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        header p {
            margin: 0;
            color: #718096;
            font-size: 15px;
        }

        .container {
            width: 100%;
            max-width: 1100px;
            box-sizing: border-box;
        }

        /* 주요 기온 지표 카드 (KPI) */
        .kpi-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .kpi-card {
            background-color: var(--card-bg);
            border-radius: 14px;
            padding: 22px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
            border: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        .kpi-card .title {
            font-size: 14px;
            color: #718096;
            margin-bottom: 6px;
            font-weight: bold;
        }

        .kpi-card .value {
            font-size: 28px;
            font-weight: 800;
            margin-top: 2px;
        }

        .kpi-card .sub-text {
            font-size: 12px;
            color: #a0aec0;
            margin-top: 8px;
        }

        /* 메인 차트 카드 패널 */
        .main-card {
            background-color: var(--card-bg);
            border-radius: 16px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
            padding: 28px;
            border: 1px solid var(--border-color);
            margin-bottom: 20px;
        }

        .controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 22px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .tabs {
            display: flex;
            gap: 8px;
        }

        .tab-btn {
            background-color: #edf2f7;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            color: #4a5568;
            transition: all 0.2s ease-in-out;
        }

        .tab-btn.active {
            background-color: var(--primary);
            color: white;
        }

        /* 파일 문제 발생 시 수동 백업 도구 */
        .upload-zone {
            border: 2px dashed #cbd5e0;
            padding: 10px 18px;
            text-align: center;
            border-radius: 8px;
            background-color: #f7fafc;
            font-size: 13px;
            color: #718096;
        }
        
        .upload-zone label {
            color: var(--primary);
            font-weight: bold;
            cursor: pointer;
            text-decoration: underline;
        }

        .chart-container {
            position: relative;
            width: 100%;
            height: 520px;
        }

        /* 알림 상태창 */
        #status-message {
            padding: 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
            line-height: 1.6;
            display: none;
        }
        
        .status-loading { display: block !important; background-color: #e2e8f0; color: #4a5568; }
        .status-error { display: block !important; background-color: #fff5f5; color: #c53030; border-left: 5px solid #e53e3e; }
        .status-success { display: block !important; background-color: #f0fff4; color: #22543d; border-left: 5px solid #38a169; }
    </style>
</head>
<body>

    <header>
        <h1>🌤️ 서울 기온 변동 트렌드 대시보드</h1>
        <p><strong>서울_기온.csv</strong> 파일을 분석하여 월간 평균 및 최고·최저 기온 변화를 시각화합니다.</p>
    </header>

    <div class="container">
        <div id="status-message"></div>

        <div class="kpi-container">
            <div class="kpi-card" style="border-top: 4px solid var(--success);">
                <div class="title">연평균 기온</div>
                <div class="value" id="kpi-avg" style="color: var(--success);">- °C</div>
                <div class="sub-text">1년 전체 측정치 평균값</div>
            </div>
            <div class="kpi-card" style="border-top: 4px solid var(--danger);">
                <div class="title">연최고 기온 (Peak)</div>
                <div class="value" id="kpi-max" style="color: var(--danger);">- °C</div>
                <div class="sub-text" id="kpi-max-date">최고 기온 발생 일시</div>
            </div>
            <div class="kpi-card" style="border-top: 4px solid var(--primary);">
                <div class="title">연최저 기온 (Floor)</div>
                <div class="value" id="kpi-min" style="color: var(--primary);">- °C</div>
                <div class="sub-text" id="kpi-min-date">최저 기온 발생 일시</div>
            </div>
        </div>

        <div class="main-card">
            <div class="controls">
                <div class="tabs">
                    <button class="tab-btn active" onclick="switchView('all')">종합 기온 변화</button>
                    <button class="tab-btn" onclick="switchView('avg')">월평균 기온</button>
                    <button class="tab-btn" onclick="switchView('extreme')">최고 vs 최저 편차</button>
                </div>
                
                <div class="upload-zone" id="drop-zone">
                    <span>서버 파일 로드 실패 시: </span>
                    <label for="csv-file">파일 직접 선택</label>
                    <input type="file" id="csv-file" accept=".csv" style="display: none;">
                </div>
            </div>

            <div class="chart-container">
                <canvas id="tempChart"></canvas>
            </div>
        </div>
    </div>

    <script>
        // ==========================================
        // ⚙️ 실제 업로드된 파일의 명칭 및 컬럼 설정
        // ==========================================
        const CONFIG = {
            csvFileName: '서울_기온.csv', 
            columnDate: '일시',          
            columnTemp: '기온(°C)'       
        };

        let chartInstance = null;
        let processedData = null; 
        let currentView = 'all';  

        document.addEventListener('DOMContentLoaded', () => {
            // 1. 자동으로 같은 폴더 안의 '서울_기온.csv' 파일 로드 시도
            fetchServerCSV();

            // 2. 수동 선택 컴포넌트 바인딩
            document.getElementById('csv-file').addEventListener('change', (e) => {
                if (e.target.files.length > 0) processFile(e.target.files[0]);
            });
            const dropZone = document.getElementById('drop-zone');
            dropZone.addEventListener('dragover', (e) => e.preventDefault());
            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                if (e.dataTransfer.files.length > 0) processFile(e.dataTransfer.files[0]);
            });
        });

        function showMessage(text, type) {
            const el = document.getElementById('status-message');
            el.className = ''; 
            el.innerHTML = text;
            if (type === 'loading') el.classList.add('status-loading');
            if (type === 'error') el.classList.add('status-error');
            if (type === 'success') el.classList.add('status-success');
        }

        // 서버 원격 패치 실행
        async function fetchServerCSV() {
            showMessage(`🔄 <strong>${CONFIG.csvFileName}</strong> 데이터를 서버에서 불러와 분석 중입니다...`, 'loading');
            try {
                const response = await fetch(`${CONFIG.csvFileName}?t=${new Date().getTime()}`);
                if (!response.ok) {
                    throw new Error(`
                        <strong>서버에서 <code>${CONFIG.csvFileName}</code> 파일을 로드하지 못했습니다. (404 Error)</strong><br>
                        주요 조치 사항:<br>
                        1. GitHub Repository 메인 화면에 <code>서울_기온.csv</code> 파일이 정확히 업로드되었는지 확인해 주세요.<br>
                        2. 파일명에 오탈자나 확장자 대소문자 불일치가 없는지 확인해 주세요.<br><br>
                        💡 <strong>[즉시 테스트하기]</strong> 오른쪽 '파일 직접 선택'을 클릭하고 내 PC의 <code>서울_기온.csv</code>를 지정하면 즉시 시각화됩니다!
                    `);
                }
                const csvText = await response.text();
                parseAndProcess(csvText, '서버 원격 데이터를 성공적으로 집계 및 분석 완료했습니다.');
            } catch (error) {
                showMessage(error.message, 'error');
            }
        }

        // 로컬 수동 파일 선택 처리
        function processFile(file) {
            showMessage(`📂 로컬 파일 로드 중: <strong>${file.name}</strong>`, 'loading');
            const reader = new FileReader();
            reader.onload = function(e) {
                parseAndProcess(e.target.result, `선택한 <code>${file.name}</code> 파일 기반 데이터 분석 완료!`);
            };
            reader.readAsText(file, 'UTF-8'); // 주신 파일 인코딩 규칙에 맞춤
        }

        // 시간별 로우 데이터 -> 월간 통계 데이터 집계 엔진
        function parseAndProcess(csvText, successMsg) {
            try {
                const lines = csvText.split(/\r?\n/).filter(line => line.trim() !== '');
                if (lines.length === 0) throw new Error("CSV 파일 내부 내용이 비어있습니다.");

                // 첫 행 헤더 추출 및 정규화
                const headers = lines[0].split(',').map(h => h.trim().replace(/^["']|["']$/g, ''));
                
                // 유연한 매칭 구조 지원
                let idxDate = headers.indexOf(CONFIG.columnDate);
                let idxTemp = headers.indexOf(CONFIG.columnTemp);
                if (idxDate === -1) idxDate = headers.findIndex(h => h.includes('일시'));
                if (idxTemp === -1) idxTemp = headers.findIndex(h => h.includes('기온'));

                if (idxDate === -1 || idxTemp === -1) {
                    throw new Error(`파일 매칭 실패: <code>일시</code> 또는 <code>기온</code> 열을 찾을 수 없습니다.<br>현재 파일 헤더: [ ${headers.join(', ')} ]`);
                }

                let annualSum = 0;
                let annualMax = -Infinity;
                let annualMaxDate = '';
                let annualMin = Infinity;
                let annualMinDate = '';
                let totalRecords = 0;

                const monthlyGroup = {};

                for (let i = 1; i < lines.length; i++) {
                    const row = lines[i].split(',');
                    if (row.length <= Math.max(idxDate, idxTemp)) continue;

                    const dateStr = row[idxDate].trim().replace(/^["']|["']$/g, '');
                    const tempVal = parseFloat(row[idxTemp].trim().replace(/,/g, ''));

                    if (isNaN(tempVal) || !dateStr || dateStr.length < 7) continue;
                    
                    // '2025-01-01 01:00' -> '2025-01' 자르기
                    const month = dateStr.substring(0, 7); 

                    if (!monthlyGroup[month]) {
                        monthlyGroup[month] = { sum: 0, max: -Infinity, min: Infinity, count: 0 };
                    }

                    monthlyGroup[month].sum += tempVal;
                    monthlyGroup[month].count++;
                    if (tempVal > monthlyGroup[month].max) monthlyGroup[month].max = tempVal;
                    if (tempVal < monthlyGroup[month].min) monthlyGroup[month].min = tempVal;

                    // 연간 전역 지표 집계
                    annualSum += tempVal;
                    totalRecords++;
                    if (tempVal > annualMax) {
                        annualMax = tempVal;
                        annualMaxDate = dateStr;
                    }
                    if (tempVal < annualMin) {
                        annualMin = tempVal;
                        annualMinDate = dateStr;
                    }
                }

                const labels = [];
                const averages = [];
                const maxes = [];
                const mins = [];

                // 월별 순서대로 정렬하여 가공 배열 채우기
                Object.keys(monthlyGroup).sort().forEach(month => {
                    // 데이터 기록이 극히 적은 노이즈 아웃라이어 데이터 행 제외
                    if(monthlyGroup[month].count < 10) return;

                    labels.push(month);
                    averages.push(parseFloat((monthlyGroup[month].sum / monthlyGroup[month].count).toFixed(1)));
                    maxes.push(monthlyGroup[month].max);
                    mins.push(monthlyGroup[month].min);
                });

                processedData = { labels, averages, maxes, mins };

                // KPI 대시보드 스코어 보드 데이터 매핑
                document.getElementById('kpi-avg').textContent = (annualSum / totalRecords).toFixed(1) + ' °C';
                document.getElementById('kpi-max').textContent = annualMax.toFixed(1) + ' °C';
                document.getElementById('kpi-max-date').textContent = `최고 시점: ${annualMaxDate}`;
                document.getElementById('kpi-min').textContent = annualMin.toFixed(1) + ' °C';
                document.getElementById('kpi-min-date').textContent = `최저 시점: ${annualMinDate}`;

                showMessage(`✅ ${successMsg}`, 'success');
                renderChart();

            } catch (err) {
                showMessage(err.message, 'error');
            }
        }

        // 탭 토글 시스템
        function switchView(viewType) {
            currentView = viewType;
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            renderChart();
        }

        // 차트 그리기 코어 함수
        function renderChart() {
            if (!processedData) return;
            const ctx = document.getElementById('tempChart').getContext('2d');
            
            if (chartInstance) chartInstance.destroy();

            let datasets = [];

            if (currentView === 'all') {
                // 1. 종합 분석 모드 (최고, 평균, 최저 기온 트렌드 라인 차트)
                datasets = [
                    {
                        label: '월최고 기온 (°C)',
                        data: processedData.maxes,
                        borderColor: 'rgba(229, 62, 62, 1)',
                        backgroundColor: 'rgba(229, 62, 62, 0.1)',
                        borderWidth: 2,
                        tension: 0.3,
                        pointRadius: 4
                    },
                    {
                        label: '월평균 기온 (°C)',
                        data: processedData.averages,
                        borderColor: 'rgba(56, 161, 105, 1)',
                        backgroundColor: 'rgba(56, 161, 105, 0.1)',
                        borderWidth: 3,
                        tension: 0.3,
                        pointRadius: 4,
                        fill: false
                    },
                    {
                        label: '월최저 기온 (°C)',
                        data: processedData.mins,
                        borderColor: 'rgba(49, 130, 206, 1)',
                        backgroundColor: 'rgba(49, 130, 206, 0.1)',
                        borderWidth: 2,
                        tension: 0.3,
                        pointRadius: 4
                    }
                ];
            } else if (currentView === 'avg') {
                // 2. 월평균 기온 전용 바 차트
                datasets = [{
                    label: '월평균 기온 (°C)',
                    data: processedData.averages,
                    backgroundColor: processedData.averages.map(v => v >= 0 ? 'rgba(56, 161, 105, 0.7)' : 'rgba(49, 130, 206, 0.7)'),
                    borderColor: processedData.averages.map(v => v >= 0 ? 'rgba(56, 161, 105, 1)' : 'rgba(49, 130, 206, 1)'),
                    borderWidth: 1,
                    type: 'bar'
                }];
            } else if (currentView === 'extreme') {
                // 3. 최고 vs 최저 기온 편차 비교 차트
                datasets = [
                    {
                        label: '월최고 기온 (°C)',
                        data: processedData.maxes,
                        backgroundColor: 'rgba(229, 62, 62, 0.7)',
                        type: 'bar'
                    },
                    {
                        label: '월최저 기온 (°C)',
                        data: processedData.mins,
                        backgroundColor: 'rgba(49, 130, 206, 0.7)',
                        type: 'bar'
                    }
                ];
            }

            chartInstance = new Chart(ctx, {
                data: {
                    labels: processedData.labels,
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', labels: { font: { weight: 'bold' } } },
                        tooltip: { mode: 'index', intersect: false }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            title: { display: true, text: '조회 연월' }
                        },
                        y: {
                            title: { display: true, text: '기온 (°C)', font: { weight: 'bold' } },
                            beginAtZero: false
                        }
                    }
                }
            });
        }
    </script>
</body>
</html>

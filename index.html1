<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>월별 전력 수급 현황 시각화</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg-color: #f4f7f6;
            --card-bg: #ffffff;
            --text-color: #2c3e50;
            --border-color: #e2e8f0;
            --primary-color: #3182ce;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        header {
            margin-bottom: 25px;
            text-align: center;
        }

        header h1 {
            margin: 0 0 8px 0;
            color: var(--primary-color);
            font-size: 28px;
        }

        header p {
            margin: 0;
            color: #718096;
            font-size: 14px;
        }

        .container {
            width: 100%;
            max-width: 1000px;
            background-color: var(--card-bg);
            border-radius: 14px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
            padding: 30px;
            box-sizing: border-box;
            border: 1px solid var(--border-color);
        }

        /* 404 에러 방지용 수동 파일 선택 영역 */
        .upload-zone {
            border: 2px dashed #cbd5e0;
            padding: 20px;
            text-align: center;
            border-radius: 8px;
            background-color: #f7fafc;
            margin-bottom: 20px;
            transition: all 0.2s;
            font-size: 14px;
        }
        
        .upload-zone:hover {
            border-color: var(--primary-color);
            background-color: #ebf8ff;
        }

        .upload-zone label {
            color: var(--primary-color);
            font-weight: bold;
            cursor: pointer;
            text-decoration: underline;
        }

        .chart-container {
            position: relative;
            width: 100%;
            height: 500px;
            margin-top: 10px;
        }

        /* 메시지 알림 창 스타일 */
        #status-message {
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            font-size: 14px;
            line-height: 1.6;
            display: none;
        }
        
        .status-loading {
            display: block !important;
            background-color: #e2e8f0;
            color: #4a5568;
        }

        .status-error {
            display: block !important;
            background-color: #fff5f5;
            color: #c53030;
            border-left: 4px solid #e53e3e;
        }

        .status-success {
            display: block !important;
            background-color: #f0fff4;
            color: #22543d;
            border-left: 4px solid #38a169;
        }
    </style>
</head>
<body>

    <header>
        <h1>월별 전력 수급 현황</h1>
        <p>CSV 데이터를 활용한 공급능력 및 최대부하 비교 대시보드</p>
    </header>

    <div class="container">
        <div id="status-message"></div>

        <div class="upload-zone" id="drop-zone">
            <span>서버에서 CSV를 읽지 못했다면? </span>
            <label for="csv-file">여기에서 CSV 파일을 직접 선택</label>
            <span>하거나 파일을 이 창 안으로 끌어다 놓으세요(Drag & Drop).</span>
            <input type="file" id="csv-file" accept=".csv" style="display: none;">
        </div>

        <div class="chart-container">
            <canvas id="powerChart"></canvas>
        </div>
    </div>

    <script>
        // ==========================================
        // ⚙️ 내 CSV 파일에 맞게 수정하는 곳
        // ==========================================
        const CONFIG = {
            csvFileName: 'electricity_data.csv', // 👈 [주의] 저장소에 올린 실제 CSV 파일명과 '대소문자'까지 완전히 똑같이 적어주세요.
            columnMonth: '연월',                    
            columnSupply: '공급능력(MW)',            
            columnDemand: '최대부하(MW)'             
        };

        let chartInstance = null; // 차트 중복 생성 방지용 객체 변수

        document.addEventListener('DOMContentLoaded', () => {
            // 1. 자동으로 서버에 있는 CSV 파일 로드 시도
            fetchServerCSV();

            // 2. 사용자가 파일을 수동으로 넣었을 때 처리하는 이벤트 바인딩
            const fileInput = document.getElementById('csv-file');
            fileInput.addEventListener('change', (e) => {
                if (e.target.files.length > 0) processFile(e.target.files[0]);
            });

            const dropZone = document.getElementById('drop-zone');
            dropZone.addEventListener('dragover', (e) => e.preventDefault());
            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                if (e.dataTransfer.files.length > 0) processFile(e.dataTransfer.files[0]);
            });
        });

        // 상태 메시지 제어 함수
        function showMessage(text, type) {
            const el = document.getElementById('status-message');
            el.className = ''; 
            el.innerHTML = text;
            if (type === 'loading') el.classList.add('status-loading');
            if (type === 'error') el.classList.add('status-error');
            if (type === 'success') el.classList.add('status-success');
        }

        // [방법 1] 서버(GitHub Pages)에서 파일 원격으로 가져오기
        async function fetchServerCSV() {
            showMessage(`🔄 서버에서 <strong>${CONFIG.csvFileName}</strong> 데이터를 불러오는 중입니다...`, 'loading');
            try {
                // 브라우저 캐시 방지를 위해 랜덤 쿼리 스트링 추가 (?t=...)
                const response = await fetch(`${CONFIG.csvFileName}?t=${new Date().getTime()}`);
                
                if (!response.ok) {
                    throw new Error(`
                        <strong>원격 CSV 파일을 찾지 못했습니다 (404 Error)</strong><br>
                        지정된 파일명인 <code>${CONFIG.csvFileName}</code>가 GitHub 레포지토리에 올바르게 저장되었는지 확인해 주세요.<br>
                        <br>
                        💡 <strong>[바로 테스트하기]</strong> 아래 회색 박스를 클릭하여 내 컴퓨터에 있는 CSV 파일을 직접 업로드하면 즉시 차트가 나타납니다!
                    `);
                }
                
                const csvText = await response.text();
                parseAndRender(csvText, `서버 파일(<code>${CONFIG.csvFileName}</code>) 데이터를 성공적으로 로드했습니다.`);

            } catch (error) {
                showMessage(error.message, 'error');
            }
        }

        // [방법 2] 사용자가 수동으로 파일 선택/드롭했을 때 로컬에서 읽기
        function processFile(file) {
            showMessage(`📂 로컬 파일 분석 중: <strong>${file.name}</strong>`, 'loading');
            const reader = new FileReader();
            reader.onload = function(e) {
                parseAndRender(e.target.result, `내 컴퓨터의 파일(<code>${file.name}</code>)을 기반으로 시각화했습니다.`);
            };
            // 한글 인코딩(깨짐) 방지를 위해 EUC-KR 설정
            reader.readAsText(file, 'EUC-KR'); 
        }

        // CSV 문자열 파싱 후 차트 생성 호출
        function parseAndRender(csvText, successMsg) {
            try {
                const parsedData = parseCSV(csvText);
                
                if (parsedData.labels.length === 0) {
                    throw new Error(`CSV 파일을 읽었으나 설정된 열 이름(<strong>${CONFIG.columnMonth}</strong>, <strong>${CONFIG.columnSupply}</strong>, <strong>${CONFIG.columnDemand}</strong>)이 감지되지 않았습니다. CSV 파일 첫 줄의 글자들과 코드 상단의 설정을 확인해 주세요.`);
                }

                showMessage(successMsg, 'success');
                renderChart(parsedData);
            } catch (err) {
                showMessage(err.message, 'error');
            }
        }

        // 공백, 따옴표, 쉼표 예외처리가 강화된 CSV 파서
        function parseCSV(text) {
            const lines = text.split(/\r?\n/).filter(line => line.trim() !== '');
            if (lines.length === 0) return { labels: [], supply: [], demand: [] };

            // 첫 줄(헤더) 분리 및 정리
            const headers = lines[0].split(',').map(h => h.trim().replace(/^["']|["']$/g, ''));
            const idxMonth = headers.indexOf(CONFIG.columnMonth);
            const idxSupply = headers.indexOf(CONFIG.columnSupply);
            const idxDemand = headers.indexOf(CONFIG.columnDemand);

            if (idxMonth === -1 || idxSupply === -1 || idxDemand === -1) {
                return { labels: [], supply: [], demand: [] };
            }

            const labels = [];
            const supply = [];
            const demand = [];

            for (let i = 1; i < lines.length; i++) {
                // 따옴표 내부 쉼표 무시하는 분할 정규식
                const row = lines[i].match(/(".*?"|[^",\s]+)(?=\s*,|\s*$)/g) || lines[i].split(',');
                const cleanRow = row.map(cell => cell.trim().replace(/^["']|["']$/g, ''));
                
                if (cleanRow.length <= Math.max(idxMonth, idxSupply, idxDemand)) continue;

                labels.push(cleanRow[idxMonth]);
                // 세 자릿수 콤마(,) 제거 후 숫자로 파싱
                supply.push(parseFloat(cleanRow[idxSupply].replace(/,/g, '')) || 0);
                demand.push(parseFloat(cleanRow[idxDemand].replace(/,/g, '')) || 0);
            }

            return { labels, supply, demand };
        }

        // Chart.js 시각화 렌더링
        function renderChart(data) {
            const ctx = document.getElementById('powerChart').getContext('2d');
            
            // 기존 차트 인스턴스가 존재하면 완전히 삭제 후 재성성 (겹침 에러 해결)
            if (chartInstance) {
                chartInstance.destroy();
            }
            
            chartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.labels,
                    datasets: [
                        {
                            label: CONFIG.CONFIG ? CONFIG.columnSupply : CONFIG.columnSupply,
                            data: data.supply,
                            backgroundColor: 'rgba(49, 130, 206, 0.7)',
                            borderColor: 'rgba(49, 130, 206, 1)',
                            borderWidth: 1,
                            type: 'bar',
                            order: 2
                        },
                        {
                            label: CONFIG.columnDemand,
                            data: data.demand,
                            backgroundColor: 'rgba(229, 62, 62, 0.15)',
                            borderColor: 'rgba(229, 62, 62, 1)',
                            borderWidth: 3,
                            type: 'line',
                            tension: 0.3,
                            pointRadius: 4,
                            order: 1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: { mode: 'index', intersect: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: false,
                            title: { display: true, text: '전력량 (MW)', font: { weight: 'bold' } }
                        },
                        x: {
                            title: { display: true, text: '연월', font: { weight: 'bold' } }
                        }
                    }
                }
            });
        }
    </script>
</body>
</html>

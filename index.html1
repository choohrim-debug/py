        const CONFIG = {
            columnDate: '일시',          
            columnValue: '전력수요(MWh)'  
        };

        let chartInstance = null;
        let globalAggregatedData = null; 
        let currentView = 'mix';         

        document.addEventListener('DOMContentLoaded', () => {
            // 외부 파일 로드 대신 코드가 켜지자마자 문자열 데이터를 즉시 분석
            parseAndProcess(DEFAULT_CSV_DATA, '내장된 전력수요 데이터(500행)를 성공적으로 연동했습니다.');

            // 추후 사용자가 로컬에서 대용량 전체 파일을 수동으로 선택했을 때의 이벤트 처리
            document.getElementById('csv-file').addEventListener('change', (e) => {
                if (e.target.files.length > 0) {
                    const file = e.target.files[0];
                    const reader = new FileReader();
                    reader.onload = function(evt) {
                        parseAndProcess(evt.target.result, `선택하신 전체 파일(<code>${file.name}</code>) 기반 대시보드 변환 성공!`);
                    };
                    reader.readAsText(file, 'UTF-8');
                }
            });
        });

        function showMessage(text) {
            document.getElementById('status-message').innerHTML = text;
        }

        // 시간별 로우 데이터 -> 일별 통계 데이터 변환
        function parseAndProcess(csvText, successMsg) {
            try {
                const lines = csvText.split(/\r?\n/).filter(line => line.trim() !== '');
                if (lines.length === 0) return;

                const headers = lines[0].split(',').map(h => h.trim().replace(/^["']|["']$/g, ''));
                const idxDate = headers.indexOf(CONFIG.columnDate);
                const idxValue = headers.indexOf(CONFIG.columnValue);

                if (idxDate === -1 || idxValue === -1) {
                    alert('CSV 구조 에러: 일시 또는 전력수요(MWh) 열이 없습니다.');
                    return;
                }

                let annualTotal = 0;
                let annualMax = -Infinity;
                let annualMaxDate = '';
                let totalRecords = 0;

                const dailyGroup = {};

                for (let i = 1; i < lines.length; i++) {
                    const row = lines[i].split(',');
                    if (row.length <= Math.max(idxDate, idxValue)) continue;

                    const dateStr = row[idxDate].trim().replace(/^["']|["']$/g, '');
                    const val = parseFloat(row[idxValue].trim().replace(/,/g, '')) || 0;

                    if (!dateStr || dateStr.length < 10) continue;
                    
                    // "2025-01-01 01:00" -> 앞 10자리인 "2025-01-01"을 추출하여 '일별'로 그룹화
                    const day = dateStr.substring(0, 10); 

                    if (!dailyGroup[day]) {
                        dailyGroup[day] = { sum: 0, max: -Infinity, count: 0 };
                    }

                    dailyGroup[day].sum += val;
                    dailyGroup[day].count++;
                    if (val > dailyGroup[day].max) {
                        dailyGroup[day].max = val;
                    }

                    annualTotal += val;
                    totalRecords++;
                    if (val > annualMax) {
                        annualMax = val;
                        annualMaxDate = dateStr;
                    }
                }

                const labels = [];
                const totals = [];
                const maxes = [];
                const averages = [];

                Object.keys(dailyGroup).sort().forEach(day => {
                    labels.push(day.substring(5)); // 차트 가독성을 위해 "2025-"를 제외한 "01-01" 형태로 라벨 삽입
                    totals.push(dailyGroup[day].sum);
                    maxes.push(dailyGroup[day].max);
                    averages.push(Math.round(dailyGroup[day].sum / dailyGroup[day].count));
                });

                globalAggregatedData = { labels, totals, maxes, averages };

                // KPI 요약카드 반영
                document.getElementById('kpi-total').textContent = annualTotal.toLocaleString() + ' MWh';
                document.getElementById('kpi-max').textContent = annualMax.toLocaleString() + ' MWh';
                document.getElementById('kpi-max-date').textContent = `피크 시점: ${annualMaxDate}`;
                document.getElementById('kpi-avg').textContent = Math.round(annualTotal / totalRecords).toLocaleString() + ' MWh';

                showMessage("✅ " + successMsg);
                renderChart();

            } catch (err) {
                console.error(err);
            }
        }

        function switchView(viewType) {
            currentView = viewType;
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            renderChart();
        }

        // Chart.js 시각화 렌더링
        function renderChart() {
            if (!globalAggregatedData) return;
            const ctx = document.getElementById('powerChart').getContext('2d');
            
            if (chartInstance) chartInstance.destroy();

            let datasets = [];

            if (currentView === 'mix') {
                datasets = [
                    {
                        label: '일별 총 수요합계 (좌축 바)',
                        data: globalAggregatedData.totals,
                        backgroundColor: 'rgba(43, 108, 176, 0.6)',
                        borderColor: 'rgba(43, 108, 176, 1)',
                        borderWidth: 1,
                        type: 'bar',
                        yAxisID: 'y'
                    },
                    {
                        label: '일별 최고 피크수요 (우축 라인)',
                        data: globalAggregatedData.maxes,
                        backgroundColor: 'rgba(221, 107, 32, 0.15)',
                        borderColor: 'rgba(221, 107, 32, 1)',
                        borderWidth: 3,
                        type: 'line',
                        tension: 0.2,
                        pointRadius: 4,
                        yAxisID: 'y1'
                    }
                ];
            } else if (currentView === 'sum') {
                datasets = [{
                    label: '일별 총 전력수요 (MWh)',
                    data: globalAggregatedData.totals,
                    backgroundColor: 'rgba(49, 151, 149, 0.7)',
                    borderColor: 'rgba(49, 151, 149, 1)',
                    borderWidth: 1,
                    type: 'bar'
                }];
            } else if (currentView === 'peak') {
                datasets = [
                    {
                        label: '일별 최고 피크 전력 (MWh)',
                        data: globalAggregatedData.maxes,
                        borderColor: 'rgba(229, 62, 62, 1)',
                        backgroundColor: 'rgba(229, 62, 62, 0.1)',
                        borderWidth: 3,
                        type: 'line',
                        tension: 0.2
                    },
                    {
                        label: '일별 시간당 평균 수요 (MWh)',
                        data: globalAggregatedData.averages,
                        borderColor: 'rgba(49, 130, 206, 1)',
                        backgroundColor: 'transparent',
                        borderWidth: 2,
                        borderDash: [5, 5],
                        type: 'line',
                        tension: 0.2
                    }
                ];
            }

            chartInstance = new Chart(ctx, {
                data: {
                    labels: globalAggregatedData.labels,
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', labels: { font: { weight: 'bold' } } },
                        tooltip: { mode: 'index', intersect: false }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            title: { display: true, text: '조회 일자 (월-일)' }
                        },
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            title: { display: true, text: currentView === 'mix' ? '일일 총 수요량 (MWh)' : '전력량 (MWh)' },
                            beginAtZero: false
                        },
                        y1: {
                            type: 'linear',
                            display: currentView === 'mix',
                            position: 'right',
                            title: { display: true, text: '순간 최고 피크 (MWh)' },
                            grid: { drawOnChartArea: false },
                            beginAtZero: false
                        }
                    }
                }
            });
        }
    </script>
</body>
</html>
